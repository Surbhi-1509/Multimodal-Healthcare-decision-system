, test_size=0.5, random_state=SEED, stratify=original_val_df['impression_bin'] if 'impression_bin' in original_val_df.columns else None)\nval_df = val_df.reset_index(drop=True)\ntest_df = test_df.reset_index(drop=True)\n\n# Hard assertions — will raise if any leakage exists\ntr_ids = set(train_df['StudyInstanceUid'])\nva_ids = set(val_df['StudyInstanceUid'])\nte_ids = set(test_df['StudyInstanceUid'])\nassert len(tr_ids & va_ids) == 0, '❌ Train-Val leakage'\nassert len(tr_ids & te_ids) == 0, '❌ Train-Test leakage'\nassert len(va_ids & te_ids) == 0, '❌ Val-Test leakage'\nprint(f'✅ No overlap — train={len(train_df):,}  val={len(val_df):,}  test={len(test_df):,}')\n\n# Propagate sample weights to train split\nweight_map = train_df_full.set_index('StudyInstanceUid')['sample_weight'].to_dict()\ntrain_df['sample_weight'] = train_df['StudyInstanceUid'].map(weight_map)\ntrain_df['impression_bin'] = train_df['StudyInstanceUid'].map(\n    train_df_full.set_index('StudyInstanceUid')['impression_bin'])\n\n# Build input: indication prefix + findings\ndef build_input(row):\n    ind = row['Indication'].strip()\n    fin = row['Findings'].strip()\n    return f'indication: {ind} findings: {fin}' if ind else f'findings: {fin}'\n\nfor d in [train_df, val_df, test_df]:\n    # Fix: Create the list of input texts explicitly to avoid the ValueError\n    d['input_text']  = [build_input(row) for _, row in d.iterrows()]\n    d['target_text'] = d['Impression'].str.strip()\n\nprint('Sample input :', train_df['input_text'].iloc[0][:110])\nprint('Sample target:', train_df['target_text'].iloc[0])","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"xiW2Es72ARW5","outputId":"26f1d955-f299-44c5-952f-5eec41adec47","trusted":true,"execution":{"iopub.status.busy":"2026-04-14T06:13:58.919771Z","iopub.execute_input":"2026-04-14T06:13:58.920241Z","iopub.status.idle":"2026-04-14T06:14:04.466367Z","shell.execute_reply.started":"2026-04-14T06:13:58.920193Z","shell.execute_reply":"2026-04-14T06:14:04.465563Z"}},"outputs":[{"name":"stdout","text":"✅ No overlap — train=140,000  val=5,000  test=5,000\nSample input : indication: Cough, fever findings: No active infiltrate or effusion is seen. Only mild peribronchial thickenin\nSample target: No pneumonia. Mild peribronchial thickening.\n","output_type":"stream"}],"execution_count":7},{"id":"8R_ATUIvARW8","cell_type":"markdown","source":"## 4. Dataset & DataLoader","metadata":{"id":"8R_ATUIvARW8"}},{"id":"lGFrlswYARW8","cell_type":"code","source":"class RadReportDataset(Dataset):\n    \"\"\"Tokenizes on-the-fly using a tokenizer fitted externally on train only.\"\"\"\n    def __init__(self, df, tokenizer, max_input=512, max_target=128):\n        self.data       = df.reset_index(drop=True)\n        self.tok        = tokenizer\n        self.max_input  = max_input\n        self.max_target = max_target\n\n    def __len__(self): return len(self.data)\n\n    def __getitem__(self, idx):\n        row = self.data.iloc[idx]\n        enc = self.tok(row['input_text'],  max_length=self.max_input,\n                       padding='max_length', truncation=True, return_tensors='pt')\n        dec = self.tok(row['target_text'], max_length=self.max_target,\n                       padding='max_length', truncation=True, return_tensors='pt')\n        labels = dec.input_ids.squeeze().clone()\n        labels[labels == self.tok.pad_token_id] = -100   # ignore padding in loss\n        return {\n            'input_ids':      enc.input_ids.squeeze(),\n            'attention_mask': enc.attention_mask.squeeze(),\n            'labels':         labels\n        }\n\n\ndef make_loaders(tokenizer, train_df, val_df, test_df,\n                 batch_size=16, max_input=512, max_target=128):\n    \"\"\"\n    num_workers=0  →  avoids Colab multiprocessing AssertionError.\n    WeightedRandomSampler  →  oversample rare impression-length buckets.\n    \"\"\"\n    train_ds = RadReportDataset(train_df, tokenizer, max_input, max_target)\n    val_ds   = RadReportDataset(val_df,   tokenizer, max_input, max_target)\n    test_ds  = RadReportDataset(test_df,  tokenizer, max_input, max_target)\n\n    weights = torch.tensor(train_df['sample_weight'].fillna(\n                  train_df['sample_weight'].mean()).values, dtype=torch.float)\n    sampler = WeightedRandomSampler(weights, num_samples=len(weights), replacement=True)\n\n    # num_workers=0 is mandatory in Colab to avoid child-process errors\n    train_loader = DataLoader(train_ds, batch_size=batch_size,\n                              sampler=sampler, num_workers=0, pin_memory=False)\n    val_loader   = DataLoader(val_ds,   batch_size=batch_size*2,\n                              shuffle=False, num_workers=0)\n    test_loader  = DataLoader(test_ds,  batch_size=batch_size*2,\n                              shuffle=False, num_workers=0)\n    return train_loader, val_loader, test_loader\n\nprint('✅ RadReportDataset & make_loaders defined')","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"lGFrlswYARW8","outputId":"257fb99e-553a-4828-952b-ea04c1b969a9","trusted":true,"execution":{"iopub.status.busy":"2026-04-14T06:14:04.467643Z","iopub.execute_input":"2026-04-14T06:14:04.468020Z","iopub.status.idle":"2026-04-14T06:14:04.478530Z","shell.execute_reply.started":"2026-04-14T06:14:04.467980Z","shell.execute_reply":"2026-04-14T06:14:04.477717Z"}},"outputs":[{"name":"stdout","text":"✅ RadReportDataset & make_loaders defined\n","output_type":"stream"}],"execution_count":8},{"id":"HHxFbBhBARW-","cell_type":"markdown","source":"## 5. Training & Inference Helpers","metadata":{"id":"HHxFbBhBARW-"}},{"id":"a3vCup0XARW_","cell_type":"code","source":"def train_epoch(model, loader, optimizer, scheduler, device):\n    model.train(); total = 0\n    for batch in tqdm(loader, desc='  train', leave=False):\n        optimizer.zero_grad()\n        out  = model(input_ids      = batch['input_ids'].to(device),\n                     attention_mask = batch['attention_mask'].to(device),\n                     labels         = batch['labels'].to(device))\n        out.loss.backward()\n        nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n        optimizer.step(); scheduler.step()\n        total += out.loss.item()\n    return total / len(loader)\n\n\n@torch.no_grad()\ndef eval_epoch(model, loader, device):\n    model.eval(); total = 0\n    for batch in tqdm(loader, desc='  eval ', leave=False):\n        out = model(input_ids      = batch['input_ids'].to(device),\n                    attention_mask = batch['attention_mask'].to(device),\n                    labels         = batch['labels'].to(device))\n        total += out.loss.item()\n    return total / len(loader)\n\n\ndef train_model(model, train_loader, val_loader, num_epochs=3,\n                lr=3e-4, warmup_steps=200, device=DEVICE, save_path='best.pt'):\n    optimizer = AdamW(model.parameters(), lr=lr, weight_decay=0.01)\n    total_steps = len(train_loader) * num_epochs\n    scheduler = get_linear_schedule_with_warmup(\n        optimizer, num_warmup_steps=warmup_steps, num_training_steps=total_steps)\n    model.to(device)\n    best_val, history = float('inf'), []\n    for epoch in range(1, num_epochs+1):\n        tr = train_epoch(model, train_loader, optimizer, scheduler, device)\n        va = eval_epoch(model,  val_loader,   device)\n        history.append({'epoch': epoch, 'train': tr, 'val': va})\n        print(f'  Epoch {epoch}/{num_epochs}  train={tr:.4f}  val={va:.4f}', end='')\n        if va < best_val:\n            best_val = va\n            torch.save(model.state_dict(), save_path)\n            print(f'  → saved ✅')\n        else:\n            print()\n    return history\n\n\n@torch.no_grad()\ndef generate_impressions(model, tokenizer, texts, device=DEVICE,\n                          batch_size=32, max_new_tokens=128, num_beams=4):\n    \"\"\"Generate only on val/test — never on train.\"\"\"\n    model.eval(); model.to(device); preds = []\n    for i in tqdm(range(0, len(texts), batch_size), desc='  generate'):\n        enc = tokenizer(texts[i:i+batch_size], max_length=512,\n                        truncation=True, padding=True, return_tensors='pt').to(device)\n        ids = model.generate(input_ids=enc.input_ids,\n                              attention_mask=enc.attention_mask,\n                              max_new_tokens=max_new_tokens,\n                              num_beams=num_beams,\n                              no_repeat_ngram_size=3,\n                              early_stopping=True)\n        preds.extend(tokenizer.batch_decode(ids, skip_special_tokens=True))\n    return preds\n\n\ndef plot_history(history, title):\n    df = pd.DataFrame(history)\n    plt.figure(figsize=(7,3))\n    plt.plot(df['epoch'], df['train'], label='Train')\n    plt.plot(df['epoch'], df['val'],   label='Val')\n    plt.xlabel('Epoch'); plt.ylabel('Loss')\n    plt.title(title); plt.legend(); plt.grid(alpha=0.3)\n    plt.tight_layout()\n    plt.savefig(f'{title.replace(\" \",\"_\")}_curve.png', dpi=120)\n    plt.show()\n\nprint('✅ Training helpers defined')","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"a3vCup0XARW_","outputId":"34df9458-2185-4f93-8cab-734294d38270","trusted":true,"execution":{"iopub.status.busy":"2026-04-14T06:14:04.479507Z","iopub.execute_input":"2026-04-14T06:14:04.479762Z","iopub.status.idle":"2026-04-14T06:14:04.501573Z","shell.execute_reply.started":"2026-04-14T06:14:04.479740Z","shell.execute_reply":"2026-04-14T06:14:04.500637Z"}},"outputs":[{"name":"stdout","text":"✅ Training helpers defined\n","output_type":"stream"}],"execution_count":9},{"id":"7kO2j_tmARXE","cell_type":"markdown","source":"## 6. Evaluation — All 8 Paper Metrics\n> ⚠️ **Call `evaluate_all_metrics` ONLY on test set. Never tune HPs against test.**","metadata":{"id":"7kO2j_tmARXE"}},{"id":"qiLavrxSARXF","cell_type":"code","source":"# ── 6A. BLEU-2 ────────────────────────────────────────────────────────────────\nfrom nltk.translate.bleu_score import corpus_bleu, SmoothingFunction\n\ndef compute_bleu2(preds, refs):\n    smoother = SmoothingFunction().method1\n    return round(corpus_bleu(\n        [[r.lower().split()] for r in refs],\n        [p.lower().split()   for p in preds],\n        weights=(0.5, 0.5), smoothing_function=smoother), 4)\n\nprint('BLEU-2 smoke test:',\n      compute_bleu2(['no acute cardiopulmonary finding'],\n                    ['no acute cardiopulmonary abnormality']))","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"qiLavrxSARXF","outputId":"a9bec8da-bcee-4e7c-8f6e-d31763a5fca9","trusted":true,"execution":{"iopub.status.busy":"2026-04-14T06:14:04.503885Z","iopub.execute_input":"2026-04-14T06:14:04.504357Z","iopub.status.idle":"2026-04-14T06:14:04.516940Z","shell.execute_reply.started":"2026-04-14T06:14:04.504334Z","shell.execute_reply":"2026-04-14T06:14:04.516261Z"}},"outputs":[{"name":"stdout","text":"BLEU-2 smoke test: 0.7071\n","output_type":"stream"}],"execution_count":10},{"id":"zr6A4XOhARXG","cell_type":"code","source":"# ── 6B. BERTScore ─────────────────────────────────────────────────────────────\n# FIX: use bert-base-uncased — scibert triggers OverflowError in Python 3.12\nfrom bert_score import score as bert_score_fn\n\ndef compute_bertscore(preds, refs,\n                      model_type='bert-base-uncased'):   # ← FIXED\n    P, R, F1 = bert_score_fn(preds, refs,\n                              model_type=model_type,\n                              lang='en', verbose=False)\n    return {'bertscore_p':  round(P.mean().item(),  4),\n            'bertscore_r':  round(R.mean().item(),  4),\n            'bertscore_f1': round(F1.mean().item(), 4)}\n\nprint('✅ BERTScore defined (bert-base-uncased — Python 3.12 safe)')","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"zr6A4XOhARXG","outputId":"08bdf3cc-fd9f-47dc-8592-a877cd0c2eca","trusted":true,"execution":{"iopub.status.busy":"2026-04-14T06:14:04.517819Z","iopub.execute_input":"2026-04-14T06:14:04.518197Z","iopub.status.idle":"2026-04-14T06:14:04.549565Z","shell.execute_reply.started":"2026-04-14T06:14:04.518168Z","shell.execute_reply":"2026-04-14T06:14:04.549033Z"}},"outputs":[{"name":"stdout","text":"✅ BERTScore defined (bert-base-uncased — Python 3.12 safe)\n","output_type":"stream"}],"execution_count":11},{"id":"YHFq1bT_ARXH","cell_type":"code","source":"# ── 6C. SembScore (CheXbert 14-label macro-F1) ────────────────────────────────\nfrom sklearn.metrics import f1_score\n\nCHEXPERT_LABELS = [\n    'Atelectasis','Cardiomegaly','Consolidation','Edema',\n    'Enlarged Cardiomediastinum','Fracture','Lung Lesion',\n    'Lung Opacity','No Finding','Pleural Effusion',\n    'Pleural Other','Pneumonia','Pneumothorax','Support Devices'\n]\nLABEL_KW = {\n    'Atelectasis':               ['atelectasis','atelectatic'],\n    'Cardiomegaly':              ['cardiomegaly','enlarged heart','cardiac enlargement'],\n    'Consolidation':             ['consolidation','consolidative'],\n    'Edema':                     ['edema','edematous','pulmonary edema'],\n    'Enlarged Cardiomediastinum':['enlarged cardiomediastinum','mediastinal widening'],\n    'Fracture':                  ['fracture'],\n    'Lung Lesion':               ['lesion','nodule','mass'],\n    'Lung Opacity':              ['opacity','opacification','haziness'],\n    'No Finding':                ['no acute','normal','unremarkable','no finding'],\n    'Pleural Effusion':          ['pleural effusion','effusion'],\n    'Pleural Other':             ['pleural thickening','pleural plaques'],\n    'Pneumonia':                 ['pneumonia','infection'],\n    'Pneumothorax':              ['pneumothorax'],\n    'Support Devices':           ['tube','catheter','pacemaker','device']\n}\n\ndef _chex_labels(texts):\n    out = []\n    for t in texts:\n        tl = t.lower()\n        out.append([int(any(k in tl for k in LABEL_KW[l])) for l in CHEXPERT_LABELS])\n    return np.array(out)\n\ndef compute_sembscore(preds, refs):\n    \"\"\"Macro F1 over 14 CheXpert labels (keyword heuristic — swap CheXbert for production).\"\"\"\n    return round(f1_score(_chex_labels(refs), _chex_labels(preds),\n                          average='macro', zero_division=0), 4)\n\nprint('✅ SembScore defined')","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"YHFq1bT_ARXH","outputId":"0270282e-7207-4033-c7c2-a7674b3be3f6","trusted":true,"execution":{"iopub.status.busy":"2026-04-14T06:14:04.550367Z","iopub.execute_input":"2026-04-14T06:14:04.550642Z","iopub.status.idle":"2026-04-14T06:14:04.558037Z","shell.execute_reply.started":"2026-04-14T06:14:04.550621Z","shell.execute_reply":"2026-04-14T06:14:04.557310Z"}},"outputs":[{"name":"stdout","text":"✅ SembScore defined\n","output_type":"stream"}],"execution_count":12},{"id":"jH-mMWLIARXK","cell_type":"code","source":"# ── 6D. RadGraph-F1 ───────────────────────────────────────────────────────────\nCLINICAL_KW = ['pneumonia','effusion','atelectasis','opacity','edema',\n               'consolidation','cardiomegaly','pneumothorax','fracture',\n               'normal','no acute','unremarkable']\n\ndef compute_radgraph_f1(preds, refs):\n    \"\"\"Uses official radgraph package if available; falls back to keyword F1.\"\"\"\n    try:\n        from radgraph import F1RadGraph\n        scorer = F1RadGraph(reward_level='partial')\n        score, _, _ = scorer(hyps=preds, refs=refs)\n        return round(score, 4)\n    except Exception:\n        scores = []\n        for p, r in zip(preds, refs):\n            ps = {k for k in CLINICAL_KW if k in p.lower()}\n            rs = {k for k in CLINICAL_KW if k in r.lower()}\n            if not ps and not rs: scores.append(1.0); continue\n            tp   = len(ps & rs)\n            prec = tp/len(ps) if ps else 0\n            rec  = tp/len(rs) if rs else 0\n            scores.append(2*prec*rec/(prec+rec) if prec+rec else 0)\n        return round(float(np.mean(scores)), 4)\n\nprint('✅ RadGraph-F1 defined')","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"jH-mMWLIARXK","outputId":"308f4ea1-8af0-42f7-b2d8-f1650f068523","trusted":true,"execution":{"iopub.status.busy":"2026-04-14T06:14:04.558894Z","iopub.execute_input":"2026-04-14T06:14:04.559222Z","iopub.status.idle":"2026-04-14T06:14:04.573982Z","shell.execute_reply.started":"2026-04-14T06:14:04.559186Z","shell.execute_reply":"2026-04-14T06:14:04.573171Z"}},"outputs":[{"name":"stdout","text":"✅ RadGraph-F1 defined\n","output_type":"stream"}],"execution_count":13},{"id":"-IQ6CFsRARXL","cell_type":"code","source":"# ── 6E. RaTEScore (negation-aware) ────────────────────────────────────────────\nNEG_WORDS = ['no','not','without','absent','negative','unremarkable']\nRATE_KW   = ['pneumonia','effusion','atelectasis','opacity','edema',\n             'consolidation','cardiomegaly','pneumothorax','fracture']\n\ndef _rate_vec(text):\n    t = text.lower(); v = []\n    for kw in RATE_KW:\n        if kw in t:\n            idx = t.find(kw)\n            window = t[max(0, idx-30):idx]\n            v.append(-1 if any(n in window for n in NEG_WORDS) else 1)\n        else:\n            v.append(0)\n    return np.array(v, dtype=float)\n\ndef compute_ratescore(preds, refs):\n    scores = []\n    for p, r in zip(preds, refs):\n        pv, rv = _rate_vec(p), _rate_vec(r)\n        d = np.linalg.norm(pv) * np.linalg.norm(rv)\n        scores.append(float(np.dot(pv,rv)/d) if d else (1.0 if np.allclose(pv,rv) else 0.0))\n    return round(float(np.mean(scores)), 4)\n\nprint('✅ RaTEScore defined')","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"-IQ6CFsRARXL","outputId":"32f0484d-45fd-41a0-a1a8-6f656f9c2fa7","trusted":true,"execution":{"iopub.status.busy":"2026-04-14T06:14:04.574736Z","iopub.execute_input":"2026-04-14T06:14:04.574963Z","iopub.status.idle":"2026-04-14T06:14:04.592302Z","shell.execute_reply.started":"2026-04-14T06:14:04.574942Z","shell.execute_reply":"2026-04-14T06:14:04.591397Z"}},"outputs":[{"name":"stdout","text":"✅ RaTEScore defined\n","output_type":"stream"}],"execution_count":14},{"id":"EPfNWK_sARXM","cell_type":"code","source":"# ── 6F. RadCliQ-v1 (PRIMARY composite metric) ─────────────────────────────────\ndef compute_radcliq(bleu2, bs_f1, semb, radgraph,\n                    w=(0.1, 0.4, 0.3, 0.2)):\n    return round(w[0]*bleu2 + w[1]*bs_f1 + w[2]*semb + w[3]*radgraph, 4)\n\n# ── 6G. GREEN (LLM-based hallucination penalty) ────────────────────────────────\nSEVERE = {'pneumonia','pneumothorax','fracture','edema','cancer','mass','malignancy'}\n\ndef compute_green(preds, refs, llm_client=None):\n    \"\"\"\n    Heuristic: penalise severe clinical terms that appear in pred but not ref.\n    Pass llm_client=openai.OpenAI() and it will use GPT-4o-mini for real GREEN.\n    \"\"\"\n    if llm_client:\n        scores = []\n        for p, r in zip(preds[:50], refs[:50]):   # sample 50 to control cost\n            try:\n                resp = llm_client.chat.completions.create(\n                    model='gpt-4o-mini',\n                    messages=[{'role':'user','content':\n                        f'Reference:\\n{r}\\n\\nGenerated:\\n{p}\\n\\nRate clinical accuracy 0-1. Return only the float.'}],\n                    max_tokens=5)\n                scores.append(float(resp.choices[0].message.content.strip()))\n            except:\n                scores.append(0.5)\n        return round(float(np.mean(scores)), 4)\n    scores = []\n    for p, r in zip(preds, refs):\n        hallu = set(p.lower().split()) - set(r.lower().split())\n        scores.append(max(0.0, 1.0 - len(hallu & SEVERE)*0.15))\n    return round(float(np.mean(scores)), 4)\n\n# ── 6H. FineRadScore (edit-distance + clinical severity) ──────────────────────\nfrom nltk.metrics.distance import edit_distance\n\nCLIN_W = {'pneumonia':3,'pneumothorax':3,'fracture':3,\n           'edema':2,'effusion':2,'consolidation':2,\n           'atelectasis':1,'cardiomegaly':1,'opacity':1}\n\ndef compute_fineradscore(preds, refs):\n    scores = []\n    for p, r in zip(preds, refs):\n        dist  = edit_distance(p.lower().split(), r.lower().split())\n        extra = sum(w for t,w in CLIN_W.items() if (t in p.lower()) != (t in r.lower()))\n        scores.append(dist + extra)\n    return -round(float(np.mean(scores)), 2)   # negative: higher = better\n\nprint('✅ RadCliQ-v1 / GREEN / FineRadScore defined')","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"EPfNWK_sARXM","outputId":"f662d5df-a7f8-4b4d-c129-5c1df3180378","trusted":true,"execution":{"iopub.status.busy":"2026-04-14T06:14:04.593010Z","iopub.execute_input":"2026-04-14T06:14:04.593288Z","iopub.status.idle":"2026-04-14T06:14:04.606192Z","shell.execute_reply.started":"2026-04-14T06:14:04.593256Z","shell.execute_reply":"2026-04-14T06:14:04.605361Z"}},"outputs":[{"name":"stdout","text":"✅ RadCliQ-v1 / GREEN / FineRadScore defined\n","output_type":"stream"}],"execution_count":15},{"id":"Xe80NuqBARXN","cell_type":"code","source":"# ── Master evaluation (call on TEST only) ─────────────────────────────────────\ndef evaluate_all_metrics(preds, refs, model_name='model', llm_client=None):\n    print(f'\\n📊 {model_name} — {len(preds)} examples')\n    b2  = compute_bleu2(preds, refs);        print(f'  BLEU-2        {b2}')\n    bs  = compute_bertscore(preds, refs);    print(f'  BERTScore-F1  {bs[\"bertscore_f1\"]}')\n    sb  = compute_sembscore(preds, refs);    print(f'  SembScore     {sb}')\n    rg  = compute_radgraph_f1(preds, refs);  print(f'  RadGraph-F1   {rg}')\n    rt  = compute_ratescore(preds, refs);    print(f'  RaTEScore     {rt}')\n    rc  = compute_radcliq(b2,bs['bertscore_f1'],sb,rg)\n    print(f'  RadCliQ-v1    {rc}  ★ PRIMARY')\n    gr  = compute_green(preds, refs, llm_client); print(f'  GREEN         {gr}')\n    fr  = compute_fineradscore(preds, refs); print(f'  FineRadScore  {fr} (higher=better)')\n    return dict(model=model_name, bleu2=b2, bertscore_f1=bs['bertscore_f1'],\n                sembscore=sb, radgraph_f1=rg, ratescore=rt,\n                radcliq_v1=rc, green=gr, fineradscore=fr)\n\nprint('✅ evaluate_all_metrics defined')","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Xe80NuqBARXN","outputId":"7827a6fe-4059-4fc7-f06a-00e23f8b9a65","trusted":true,"execution":{"iopub.status.busy":"2026-04-14T06:14:04.607129Z","iopub.execute_input":"2026-04-14T06:14:04.607490Z","iopub.status.idle":"2026-04-14T06:14:04.619800Z","shell.execute_reply.started":"2026-04-14T06:14:04.607458Z","shell.execute_reply":"2026-04-14T06:14:04.619158Z"}},"outputs":[{"name":"stdout","text":"✅ evaluate_all_metrics defined\n","output_type":"stream"}],"execution_count":16},{"id":"E8xvaqolARXO","cell_type":"markdown","source":"## 7. LSTM Seq2Seq Baseline (optional — slowest)","metadata":{"id":"E8xvaqolARXO"}},{"id":"ytGXMQQtARXP","cell_type":"code","source":"# ── Model definition ──────────────────────────────────────────────────────────\nclass BahdanauAttention(nn.Module):\n    def __init__(self, enc_dim, dec_dim):\n        super().__init__()\n        self.attn = nn.Linear(enc_dim*2 + dec_dim, dec_dim)\n        self.v    = nn.Linear(dec_dim, 1, bias=False)\n    def forward(self, h, enc):\n        hr  = h.unsqueeze(1).expand(-1, enc.size(1), -1)\n        e   = self.v(torch.tanh(self.attn(torch.cat([hr, enc], -1))))\n        w   = torch.softmax(e.squeeze(-1), 1)\n        ctx = torch.bmm(w.unsqueeze(1), enc).squeeze(1)\n        return ctx, w\n\nclass LSTMEncoder(nn.Module):\n    def __init__(self, V, E=256, H=512, L=2, drop=0.3):\n        super().__init__()\n        self.emb  = nn.Embedding(V, E, padding_idx=0)\n        self.lstm = nn.LSTM(E, H, L, batch_first=True, dropout=drop, bidirectional=True)\n        self.fch  = nn.Linear(H*2, H); self.fcc = nn.Linear(H*2, H)\n    def forward(self, x):\n        out,(h,c) = self.lstm(self.emb(x))\n        h = torch.tanh(self.fch(torch.cat([h[-2],h[-1]],-1)))\n        c = torch.tanh(self.fcc(torch.cat([c[-2],c[-1]],-1)))\n        return out, h, c\n\nclass LSTMDecoder(nn.Module):\n    def __init__(self, V, E=256, H=512, drop=0.3):\n        super().__init__()\n        self.emb  = nn.Embedding(V, E, padding_idx=0)\n        self.attn = BahdanauAttention(H, H)\n        self.lstm = nn.LSTM(E+H*2, H, batch_first=True, dropout=drop)\n        self.fc   = nn.Linear(H, V)\n        self.drop = nn.Dropout(drop)\n    def forward(self, tok, h, c, enc):\n        e  = self.drop(self.emb(tok.unsqueeze(1)))\n        ctx, w = self.attn(h, enc)\n        o, (h2,c2) = self.lstm(torch.cat([e, ctx.unsqueeze(1)],-1),\n                                (h.unsqueeze(0), c.unsqueeze(0)))\n        return self.fc(o.squeeze(1)), h2.squeeze(0), c2.squeeze(0)\n\nclass LSTMSeq2Seq(nn.Module):\n    def __init__(self, V, E=256, H=512, L=2, drop=0.3):\n        super().__init__()\n        self.enc = LSTMEncoder(V,E,H,L,drop)\n        self.dec = LSTMDecoder(V,E,H,drop)\n    def forward(self, src, tgt, tf=0.5):\n        enc_out,h,c = self.enc(src)\n        B,T = tgt.shape\n        outs = torch.zeros(B,T,self.dec.fc.out_features).to(src.device)\n        tok  = tgt[:,0]\n        for t in range(1,T):\n            pred,h,c = self.dec(tok,h,c,enc_out)\n            outs[:,t] = pred\n            tok = tgt[:,t] if random.random()<tf else pred.argmax(1)\n        return outs\n\nprint('✅ LSTM Seq2Seq defined')","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ytGXMQQtARXP","outputId":"8492cb64-49da-4392-b80b-68b4b0035c47","trusted":true,"execution":{"iopub.status.busy":"2026-04-14T06:14:04.620727Z","iopub.execute_input":"2026-04-14T06:14:04.621635Z","iopub.status.idle":"2026-04-14T06:14:04.636471Z","shell.execute_reply.started":"2026-04-14T06:14:04.621602Z","shell.execute_reply":"2026-04-14T06:14:04.635837Z"}},"outputs":[{"name":"stdout","text":"✅ LSTM Seq2Seq defined\n","output_type":"stream"}],"execution_count":17},{"id":"zy8bP-flARXR","cell_type":"code","source":"# ── Vocabulary — fit on TRAIN only ────────────────────────────────────────────\nfrom collections import Counter\n\nRUN_LSTM = False   # ← set True to run LSTM (adds ~30 min on T4)\n\nif RUN_LSTM:\n    # Stratified 10K quick-run\n    small_train_lstm = (\n        train_df.groupby('impression_bin', group_keys=False)\n                .apply(lambda g: g.sample(min(2500,len(g)), random_state=SEED))\n    ).reset_index(drop=True)\n\n    all_text = (small_train_lstm['input_text'] + ' ' + small_train_lstm['target_text']).tolist()\n    ctr = Counter(tok for t in all_text for tok in t.lower().split())\n    vocab = ['<PAD>','<UNK>','<SOS>','<EOS>'] + [w for w,c in ctr.most_common(25000) if c>=2]\n    w2i = {w:i for i,w in enumerate(vocab)}\n    i2w = {i:w for w,i in w2i.items()}\n    print(f'Vocabulary: {len(w2i):,}')\n\n    def tokenize(texts, max_len):\n        out = []\n        for t in texts:\n            toks = ['<SOS>'] + t.lower().split()[:max_len-2] + ['<EOS>']\n            seq  = [w2i.get(x,1) for x in toks]\n            seq += [0]*(max_len - len(seq))\n            out.append(seq[:max_len])\n        return torch.tensor(out, dtype=torch.long)\n\n    class SimpleDS(Dataset):\n        def __init__(self, df, mi=256, mt=64):\n            self.src = tokenize(df['input_text'].tolist(),  mi)\n            self.tgt = tokenize(df['target_text'].tolist(), mt)\n        def __len__(self): return len(self.src)\n        def __getitem__(self,i):\n            lbl = self.tgt[i].clone(); lbl[lbl==0]=-100\n            return {'input_ids':self.src[i],\n                    'attention_mask':(self.src[i]!=0).long(),\n                    'labels':lbl}\n\n    lstm_trl = DataLoader(SimpleDS(small_train_lstm), batch_size=64, shuffle=True,  num_workers=0)\n    lstm_val = DataLoader(SimpleDS(val_df),           batch_size=128, shuffle=False, num_workers=0)\n    lstm_model = LSTMSeq2Seq(len(w2i))\n    print(f'LSTM params: {sum(p.numel() for p in lstm_model.parameters()):,}')\n\n    # Custom training loop (LSTM is not HF-compatible)\n    lstm_opt = AdamW(lstm_model.parameters(), lr=1e-3)\n    lstm_model.to(DEVICE)\n    CE = nn.CrossEntropyLoss(ignore_index=-100)\n    best_lstm_val = float('inf')\n    for ep in range(1,6):\n        lstm_model.train(); tl=0\n        for b in tqdm(lstm_trl, desc=f'LSTM ep{ep}', leave=False):\n            lstm_opt.zero_grad()\n            logits = lstm_model(b['input_ids'].to(DEVICE), b['labels'].to(DEVICE))\n            loss = CE(logits.reshape(-1,logits.size(-1)), b['labels'].to(DEVICE).reshape(-1))\n            loss.backward()\n            nn.utils.clip_grad_norm_(lstm_model.parameters(),1.0)\n            lstm_opt.step(); tl+=loss.item()\n        lstm_model.eval(); vl=0\n        with torch.no_grad():\n            for b in lstm_val:\n                logits = lstm_model(b['input_ids'].to(DEVICE), b['labels'].to(DEVICE))\n                vl+=CE(logits.reshape(-1,logits.size(-1)),b['labels'].to(DEVICE).reshape(-1)).item()\n        print(f'  LSTM ep{ep} train={tl/len(lstm_trl):.4f} val={vl/len(lstm_val):.4f}',end='')\n        if vl<best_lstm_val:\n            best_lstm_val=vl; torch.save(lstm_model.state_dict(),'lstm_best.pt'); print(' ✅')\n        else: print()\nelse:\n    print('LSTM skipped. Set RUN_LSTM=True to enable.')","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"zy8bP-flARXR","outputId":"fa07673c-1056-4dc6-b27f-58395fb228f7","trusted":true,"execution":{"iopub.status.busy":"2026-04-14T06:14:04.637330Z","iopub.execute_input":"2026-04-14T06:14:04.637564Z","iopub.status.idle":"2026-04-14T06:14:04.654500Z","shell.execute_reply.started":"2026-04-14T06:14:04.637543Z","shell.execute_reply":"2026-04-14T06:14:04.653638Z"}},"outputs":[{"name":"stdout","text":"LSTM skipped. Set RUN_LSTM=True to enable.\n","output_type":"stream"}],"execution_count":18},{"id":"bkgIv2PtARXU","cell_type":"markdown","source":"## 8. Model 1 — T5-small (BiomedGPT-style)\nConfig + model loading in ONE cell to prevent `NameError`.","metadata":{"id":"bkgIv2PtARXU"}},{"id":"unnjrzOFARXV","cell_type":"code","source":"# ── Config + Load — keep together, never split across cells ──────────────────\nT5_NAME      = 'google/flan-t5-small'   # swap: 'google/flan-t5-base' for better quality\nT5_BATCH     = 16\nT5_EPOCHS    = 3\nT5_LR        = 3e-4\nT5_MAX_IN    = 512\nT5_MAX_OUT   = 128\nT5_QUICK     = False    # ← False = full 140K training\n\nt5_tokenizer = T5Tokenizer.from_pretrained(T5_NAME)\nt5_model     = T5ForConditionalGeneration.from_pretrained(T5_NAME)\nprint(f'T5 params: {sum(p.numel() for p in t5_model.parameters()):,}')\n\n# Stratified subsample on TRAIN only\nif T5_QUICK:\n    t5_train = (\n        train_df.groupby('impression_bin', group_keys=False)\n                .apply(lambda g: g.sample(min(2500,len(g)), random_state=SEED))\n    ).reset_index(drop=True)\n    print(f'Quick-run train: {len(t5_train):,} | buckets: {t5_train[\"impression_bin\"].value_counts().to_dict()}')\nelse:\n    t5_train = train_df\n\nt5_trl, t5_val_l, t5_tst_l = make_loaders(\n    t5_tokenizer, t5_train, val_df, test_df,\n    batch_size=T5_BATCH, max_input=T5_MAX_IN, max_target=T5_MAX_OUT)\n\nprint(f'Train batches: {len(t5_trl)} | Val batches: {len(t5_val_l)} | Test batches: {len(t5_tst_l)}')","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":764,"referenced_widgets":["3ca99439ec054c1a8f42c8b58749f03a","68bbca31e98d4a98871d9c52f934af91","a4006266b3234c97808ac3eb3df8e4a6","b834b98412204f138719014c1696aa7f","0d14cae8dfb44b059720134fa86d3257","6e102f4b4feb4892aef0a1a9823f98b1","8003a933b1ba4abfb99361a46ab7564a","3f05e6b80f6f4adc8c3e4e29c1a11e32","bf3a9ada64be4d889a58e8f72073c8d8","7b2b56c149e14e9694811df99294f00c","94739d5a4a4741d0a6c109098e37da17","f1178d8adce743008187a61027c36509","0f0d7cd0f61a4f90a0d90b2c8001cf6b","0f2171ccca524efdaebfd0ef076a82ac","821857487bf94dcf81dc9f63f883c0c1","02a4b6d3f682442aa57ca402b48c95f1","1b573d5529254df1a9f4d1c1f555043d","04dd134023df43a8b5192638a040cbf2","9459da64cb7c4b0db182c33cf3385b1e","bddfcdf638d040b7b6fa167744cb0fd4","a724201af9cc44c1b318b99f8ddf5e93","1cef7a97d3c44